[http]
listen_address = 0.0.0.0
listen_port = 8080
# Only ever consulted on a genuine first run (no config file existed
# yet) — never opens a browser on an ordinary restart, so this is safe
# to leave on even for a systemd-managed deployment (see packaging/).
open_browser_on_first_run = true

[auth]
username = admin
# You don't need to compute this by hand — the settings page
# (/settings, or the setup wizard a fresh install redirects to) will
# hash whatever you type into "new password" and write it here for
# you. Manual alternative: printf '%s' "your-password" | sha256sum.
# The example hash below is for the literal password "password" —
# change it before using this file for real.
password_hash = 5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8
# Leave password_hash blank to disable login entirely (open dashboard).
session_ttl_minutes = 60
# Session length when the login page's "Remember me" checkbox is used.
remember_me_days = 30

[polling]
interval_seconds = 30
timeout_ms = 1500
retries = 2
max_concurrent_devices = 8
# Ring-buffer size per interface for the dashboard's traffic sparklines.
# 240 @ the default 30s interval = 2 hours of history; raise this if you
# want a longer trend window, at ~24 bytes/sample/interface in memory.
history_points = 240

[device:procurve-2512]
display_name = HP ProCurve 2512
host = 192.168.1.1
port = 161
community = public
version = 1

[device:core-switch]
display_name = Core Switch
host = 10.0.0.2
port = 161
community = public
version = 2c
